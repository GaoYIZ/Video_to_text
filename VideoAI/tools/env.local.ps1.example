$env:VIDEOAI_AI_BASE_URL = "https://dashscope.aliyuncs.com/compatible-mode/v1"
$env:VIDEOAI_AI_API_KEY = "replace-with-your-api-key"
$env:VIDEOAI_AI_MODEL = "qwen-plus"
$env:VIDEOAI_ASR_MODEL = "tiny"
$env:VIDEOAI_ASR_LANGUAGE = "zh"
$env:VIDEOAI_ASR_DEVICE = "cpu"
$env:VIDEOAI_ASR_COMPUTE_TYPE = "int8"
